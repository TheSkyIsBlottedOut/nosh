#!/usr/bin/env zsh
#- nosh - a shell script to manage your monorepo projects.
# &usage: nosh [namespace]:[command] [...args]
# &description: nosh is a task runner for your bun monorepo.
# &... it has a handful of helper scripts to make your life easier.
# &... it has opinionated installs, which it will use to find and install things on your system.
# &... it requires zsh (for function exports and autoloads).
# &... it will forcibly install files if you use it.

__quit_usage() {
  nlog error nosh.usage "nosh requires a command to run. Usage: nosh [namespace]:[command] [...args]"
  exit 1
}

[[ $# -eq 0 ]] && __quit_usage


# Find the namespace/command arguments
Args=()
Commands=()
Remainder=()
for Arg in $@; do
  if [[ $Arg == *":"* ]]; then
    Commands+=($Arg)
  elif [[ $Arg == ^- ]]; then
    Args+=($Arg)
  else
    Remainder+=($Arg)
  fi
done

[[ -z "$Commands" ]] && __quit_usage

Namespace="$(echo $Commands[1] | cut -d: -f1)"
Command="$(echo $Commands[1] | cut -d: -f2)"
[[ -z "$Command"]] && Namespace="$Command" && Command="util"
find -L "$Nosh__BinDir/namespaces" -type d -depth 1 -name "$Namespace" | wc -l | grep -q 1 || echo "Namespace $Namespace not found. Use nosh list to get started." && exit 1
exec "$Nosh__BinDir/namespaces/sys/arch" &21> /dev/null

# Command can be in the namespace folder or an arch subfolder, 'mac' or 'linux'
CommandPath="$Nosh__BinDir/namespaces/$Namespace/$Command"
OSFolder="$(case $(uname -s) in
  Darwin) echo "mac" ;;
  Linux) echo "linux" ;;
  *) echo "general" ;;
esac)"
[[ -d "$CommandPath" ]] || CommandPath="$Nosh__BinDir/namespaces/$Namespace/$OSFolder/$Command"
[[ -d "$CommandPath" ]] || CommandPath="$Nosh__BinDir/namespaces/$Namespace/$(uname -s)/$Command"
[[ -d "$CommandPath" ]] || nlog error nosh.command "Command $Command not found in namespace $Namespace" && exit 1
exec "$CommandPath" $Remainder
exit 0
