#!/usr/bin/env zsh
#- scrawl [level] [event] [message]
#-   Log a message to the console and optionally to a file, based on profile settings.

[[ -z "$Nosh__LogLevel_Console" ]] && export Nosh__LogLevel_Console="info"
[[ -z "$Nosh__LogLevel_File" ]] && export Nosh__LogLevel_File="info"
KnownLevels=("trace" "debug" "info" "warn" "error" "fatal")
Level="debug"
Message=":shark: :shark: :shark:"
Event="nosh.event"
source "$Nosh_LibDir/logging.zsh"

__isEvent() {
  local Event="$1"
  if [[ $Event == *"."* ]]; then
    return 0
  else
    return 1
  fi
}
if [[ $1 == "-h" || $1 == "--help" ]]; then
  __log_help
  exit 0
fi

# is #1 a known level?
if [[ $KnownLevels[(Ie)$1] -gt 0 ]]; then
  Level="$1"
  shift
else
  Level="info"
fi

# is the next argument an event?
if [[ $(__isEvent "$1") -eq 0 ]]; then
  Event="$1"
  shift
fi

if [[ $# -eq 0 ]]; then
  Message=":shark: :shark: :shark:"
else
  Message="$@"
fi
if test -t __log >/dev/null; then
  __log "$Level" "$Event" "$Message"
else
 echo "⚧ [$(date "+%Y-%m-%d %H:%M:%S")] [error] nosh.log: Error logging message." 1>&2
 echo "⚆ [$(date "+%Y-%m-%d %H:%M:%S")] <$Level> |$Event| $Message" 1>&2
fi
exit 0